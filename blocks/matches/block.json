{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "mini/matches",
    "title": "Matches",
    "category": "mini",
    "description": "Display a grid of sport matches from the Match post type.",
    "keywords": ["matches", "sport", "results", "mini"],
    "textdomain": "mini",
    "attributes": {
        "count":      { "type": "number",  "default": 6    },
        "columns":    { "type": "string",  "default": "33" },
        "categoryId": { "type": "number",  "default": 0    },
        "order":      { "type": "string",  "default": "DESC" }
    },
    "supports": { "html": false },
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
